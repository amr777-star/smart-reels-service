# LLM provider — Gemini direct (or any OpenAI-compatible: OpenRouter, Groq, etc.)
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.5-flash

# Pexels API key for B-roll (free: https://www.pexels.com/api/)
PEXELS_API_KEY=

# Jamendo API for auto BGM (free: https://devportal.jamendo.com/)
JAMENDO_CLIENT_ID=

# API key for this service (optional, leave empty to disable auth)
API_KEY=

# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# Whisper device: cpu or cuda
WHISPER_DEVICE=cpu

# CORS origins (comma-separated)
CORS_ORIGINS=*

# Server port
PORT=8100
