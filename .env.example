# Gemini API key (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Pexels API key for B-roll (free: https://www.pexels.com/api/)
PEXELS_API_KEY=

# API key for this service (optional, leave empty to disable auth)
API_KEY=

# Whisper model: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# Whisper device: cpu or cuda
WHISPER_DEVICE=cpu

# CORS origins (comma-separated)
CORS_ORIGINS=*

# Server port
PORT=8100
